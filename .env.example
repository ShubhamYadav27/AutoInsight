# AutoInsight Backend Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# MongoDB connection string
# Local: mongodb://localhost:27017/autoinsight
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/autoinsight
MONGODB_URI=mongodb://localhost:27017/autoinsight

# Server port (default: 5000)
PORT=5000

# Frontend URL for CORS (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
